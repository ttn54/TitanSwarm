# TitanSwarm — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — it is already in .gitignore.

# ── AI Provider ──────────────────────────────────────────────────────────────
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=sk-...

# ── Database ─────────────────────────────────────────────────────────────────
# Leave commented to use SQLite (default).
# Uncomment to switch to Postgres — no code changes needed.
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/titanswarm

# ── Scraper Settings ─────────────────────────────────────────────────────────
SCRAPER_ROLES=Software Engineer Intern
SCRAPER_LOCATIONS=Vancouver, BC
SCRAPER_INTERVAL_HOURS=12
SCRAPER_RESULTS_WANTED=25
